# Gemini API Key (obrigatório para funcionalidades de IA)
GEMINI_API_KEY="SUA_GEMINI_API_KEY"

# Firebase Config (obrigatório para autenticação e banco de dados)
# Use o prefixo VITE_ para que fiquem acessíveis no client-side
VITE_FIREBASE_PROJECT_ID=""
VITE_FIREBASE_APP_ID=""
VITE_FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN=""
VITE_FIREBASE_FIRESTORE_DATABASE_ID=""
VITE_FIREBASE_STORAGE_BUCKET=""
VITE_FIREBASE_MESSAGING_SENDER_ID=""

# URL do App (preenchido automaticamente em produção)
APP_URL="http://localhost:3000"
